{
    "mcpServers": {
        "claude-context": {
            "type": "stdio",
            "command": "sh",
            "args": [
                "-c",
                "export $(grep '^OPENAI_API_KEY=' .env | xargs) && exec npx --yes @zilliz/claude-context-mcp@latest"
            ],
            "env": {
                "OPENAI_API_KEY": "${OPENAI_API_KEY}",
                "MILVUS_ADDRESS": "localhost:19531"
            }
        },
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp"
            ],
            "env": {
                "DEFAULT_MINIMUM_TOKENS": "20000"
            }
        },
        "sequential-thinking": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-sequential-thinking"
            ]
        },
        "serena": {
            "type": "stdio",
            "command": "uvx",
            "args": [
                "--from",
                "git+https://github.com/oraios/serena",
                "serena",
                "start-mcp-server",
                "--context",
                "claude-code",
                "--project",
                ".",
                "--enable-web-dashboard",
                "false"
            ],
            "env": {}
        }
    }
}
